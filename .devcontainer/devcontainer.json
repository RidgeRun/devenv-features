{
    "name": "RidgeRun Devcontainer Features",
    "image": "ubuntu:24.04",
    "containerUser": "${localEnv:USER}",
    "remoteUser": "${localEnv:USER}",
    "features": {
        "./local-features/fixes": {},
        "ghcr.io/devcontainers/features/common-utils:2": {},
        "ghcr.io/devcontainers/features/docker-in-docker:4": {},
        "ghcr.io/eliises/devcontainer-features/devcontainers-cli:1": {},
        "ghcr.io/ridgerun/devcontainer-features/gstreamer": {
            "gstVersion": "1.26"
        },
        "ghcr.io/ridgerun/devcontainer-features/ridgerun-oss": {},
        "ghcr.io/ridgerun/devcontainer-features/ridgerun-proprietary": {}
    },
    "mounts": [
        {
            "source": "${localEnv:HOME}/.config",
            "target": "/home/${localEnv:USER}/.config",
            "type": "bind",
            "options": ["readonly"]
        },
        {
            "source": "${localEnv:HOME}/.gitconfig",
            "target": "/home/${localEnv:USER}/.gitconfig",
            "type": "bind",
            "options": ["readonly"]
        },
        {
            "source": "${localEnv:HOME}/.cache",
            "target": "/home/${localEnv:USER}/.cache",
            "type": "bind",
            "options": []
        },
        {
            "source": "${localEnv:HOME}/.ssh/known_hosts",
            "target": "/home/${localEnv:USER}/.ssh/known_hosts",
            "type": "bind",
            "options": ["readonly"]
        },
        {
            "source": "${localEnv:SSH_AUTH_SOCK}",
            "target": "/ssh-auth.sock",
            "type": "bind",
            "options": []
        }
    ],
    "remoteEnv": {
        "SSH_AUTH_SOCK": "/ssh-auth.sock",
        "XDG_CONFIG_HOME": "/home/${localEnv:USER}/.config",
        "XDG_CACHE_HOME": "/home/${localEnv:USER}/.cache"
    }
}
