{
    "name": "RidgeRun Devcontainer Features",
    "image": "ubuntu:24.04",
    "containerUser": "${localEnv:USER}",
    "remoteUser": "${localEnv:USER}",
    "features": {
        "./local-features/fixes": {},
        "ghcr.io/devcontainers/features/common-utils:2": {},
        "ghcr.io/devcontainers/features/docker-in-docker:4": {},
        "ghcr.io/eliises/devcontainer-features/devcontainers-cli:1": {},
        "ghcr.io/ridgerun/devcontainer-features/gstreamer:0": {
            "gstVersion": "1.26"
        },
        "ghcr.io/ridgerun/devcontainer-features/ridgerun-oss:0": {},
        "ghcr.io/ridgerun/devcontainer-features/ridgerun-proprietary:0": {},
        "ghcr.io/ridgerun/devcontainer-features/devenv:0": {
            "display": "${localEnv:DISPLAY}"
        }
    }
}
