{
    "id": "glib",
    "version": "0.1.0",
    "name": "GLib",
    "description": "Add a GLib build to a devcontainer",
    "dependsOn": {
        "ghcr.io/ridgerun/devcontainer-features/meson:0": {}
    },
    "options": {
        "glibVersion": {
            "type": "string",
            "description": "The GLib version to build"
        },
        "buildType": {
            "type": "string",
            "description": "The type of build to perform",
            "enum": ["plain", "debug", "debugoptimized", "release", "minsize"],
            "default": "debug"
        },
        "introspection": {
            "type": "boolean",
            "description": "Whether to build GObject Introspection data",
            "default": true
        },
        "extraArgs": {
            "type": "string",
            "description": "Any additional meson args to pass to the configuration step"
        }
    }
}
